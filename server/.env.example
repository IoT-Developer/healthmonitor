# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# --- MySQL ---
# Format: mysql://user:password@host:port/database
MYSQL_URL=mysql://root:password@localhost:3306/healthmonitor

# --- Auth ---
# Generate strong secrets in production!  e.g.  openssl rand -base64 48
JWT_SECRET=change-me-in-production-please
JWT_REFRESH_SECRET=change-me-too-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Simulator ---
SIMULATOR_TICK_MS=3000
SIMULATOR_ENABLED=true
